# ===========================================================================
# Production environment for docker-compose.prod.yml
#   cp .env.production.example .env.production   then fill in real values.
#   This file is read via:  docker compose --env-file .env.production ...
# NEVER commit .env.production (it is git-ignored).
# ===========================================================================

# ---- PostgreSQL (stays internal to the Docker network) ----
POSTGRES_USER=app
POSTGRES_DB=leads
# Use a long random value, e.g.  openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- DeepSeek (external LLM API) ----
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ---- WAHA (WhatsApp gateway, internal; QR via SSH tunnel) ----
WAHA_SESSION=default
# Shared between WAHA and the backend; e.g.  openssl rand -hex 24
WAHA_API_KEY=CHANGE_ME_strong_waha_api_key
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=CHANGE_ME_strong_dashboard_password

# ---- Image tags ----
# Normally injected by the GitHub Actions deploy (pinned to a commit SHA).
# Set these only for a manual run / rollback on the VPS, e.g.:
#   BACKEND_IMAGE=ghcr.io/<owner>/leads-chatbot-en-backend:<sha>
#   FRONTEND_IMAGE=ghcr.io/<owner>/leads-chatbot-en-frontend:<sha>
